    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "eslint": "^9.0.0",
    "vitest": "^2.1.0"
  },
  "engines": { "node": ">=20.0.0", "pnpm": ">=9.0.0" },
  "packageManager": "pnpm@9.0.0"
