{
  "name": "axiom",
  "private": true,
  "description": "Open-source behavioral testing infrastructure for AI applications",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
